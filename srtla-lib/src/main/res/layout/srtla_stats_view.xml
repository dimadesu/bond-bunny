<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical">

  <!-- Moblink Relays section (hidden until setRelays is called) -->
  <LinearLayout
    android:id="@+id/relays_section"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F0F0F0"
    android:layout_marginBottom="4dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:visibility="gone">

    <TextView
      android:id="@+id/text_relays_title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="Moblink Relays"
      android:textSize="14sp"
      android:textStyle="bold"
      android:textColor="#212529"
      android:paddingLeft="12dp"
      android:paddingRight="12dp"
      android:paddingBottom="4dp" />

    <LinearLayout
      android:id="@+id/relays_container"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical" />

  </LinearLayout>

  <!-- Total Bitrate Display -->
  <TextView
    android:id="@+id/text_total_bitrate"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Total: 0.00 Mbps"
    android:textSize="16sp"
    android:textColor="#495057"
    android:paddingTop="8dp"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingBottom="8dp"
    android:background="#F0F0F0" />

  <!-- Container for dynamically added connection items -->
  <LinearLayout
    android:id="@+id/connections_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Default "no connections" message -->
    <TextView
      android:id="@+id/text_no_connections"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="No active connections"
      android:textSize="16sp"
      android:textColor="#495057"
      android:padding="12dp"
      android:background="#F0F0F0"
      android:gravity="center" />
  </LinearLayout>

</LinearLayout>
